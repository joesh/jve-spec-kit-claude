{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/joe/Local/jve-spec-kit-claude/.claude/hooks/session_pid.sh 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "cozempic guard --daemon --no-reload --threshold-tokens 280000 --soft-threshold-tokens 160000 -rx aggressive --interval 60 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/joe/Local/jve-spec-kit-claude/.claude/hooks/pre_edit_gate.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "cozempic checkpoint 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "TaskCreate|TaskUpdate",
        "hooks": [
          {
            "type": "command",
            "command": "cozempic checkpoint 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/joe/Local/jve-spec-kit-claude/.claude/hooks/audit_reminder.sh"
          },
          {
            "type": "command",
            "command": "/Users/joe/Local/jve-spec-kit-claude/.claude/hooks/lint_anti_patterns_post_edit.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cozempic checkpoint 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cozempic checkpoint 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "WebFetch"
    ]
  }
}

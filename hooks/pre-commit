#!/bin/bash
# JVE pre-commit hook.
#
# Gates (in order):
#   1) Clean-build freshness — `.last-clean-make` marker (touched by `make -j4`'s
#      final recipe step) must be newer than every input `make -j4` consumes:
#      src/**/*.{cpp,mm,h,hpp,lua}, tests/**/*.lua, keymaps/**, top Makefile,
#      and CMakeLists.txt files. Proves the whole `make -j4` (compile + lint +
#      lua/binding/integration tests + keymap coverage) succeeded after the
#      latest edit, not just that a binary got linked. Stale or missing → block.
#   2) Luacheck (whole repo) — staged or not. Same scope as `make -j4`.
#   3) Anti-pattern lint — only violations on lines being introduced/modified
#      block. Pre-existing violations on untouched lines do not.
#   4) Lint-allow gate — any newly added `lint-allow:` annotation pauses the
#      commit until explicitly opted in via JVE_LINT_ALLOW_OK=1. Prevents
#      "shut up the linter" as a substitute for the real fix.
#
# Bypass for a single commit: `git commit --no-verify` (not recommended).

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0

# --- 1) clean-build freshness ------------------------------------------------
MARKER="$REPO_ROOT/.last-clean-make"
if [ ! -f "$MARKER" ]; then
    echo "PRE-COMMIT BLOCKED: no clean-build marker at ${MARKER#$REPO_ROOT/}" >&2
    echo "Run \`make -j4\` to a green finish before committing." >&2
    exit 1
fi

marker_mtime=$(stat -f %m "$MARKER")
newest_src=""
newest_mtime=0
while IFS= read -r src; do
    m=$(stat -f %m "$src")
    if [ "$m" -gt "$newest_mtime" ]; then
        newest_mtime=$m
        newest_src=$src
    fi
done < <(
    find "$REPO_ROOT/src" -type f \( -name '*.cpp' -o -name '*.mm' -o -name '*.h' -o -name '*.hpp' -o -name '*.lua' \)
    find "$REPO_ROOT/tests" -type f -name '*.lua' -not -path '*/autogen/*'
    find "$REPO_ROOT/keymaps" -type f 2>/dev/null
    find "$REPO_ROOT" -maxdepth 2 -name 'CMakeLists.txt' -not -path '*/build/*'
    echo "$REPO_ROOT/Makefile"
)

if [ "$newest_mtime" -gt "$marker_mtime" ]; then
    echo "PRE-COMMIT BLOCKED: last clean \`make -j4\` is older than newer source." >&2
    echo "  newer source: ${newest_src#$REPO_ROOT/}" >&2
    echo "  marker:       ${MARKER#$REPO_ROOT/}" >&2
    echo "Run \`make -j4\` to a green finish and re-stage." >&2
    exit 1
fi

# --- 2) luacheck (whole repo) -----------------------------------------------
# Matches `make -j4`'s luacheck scope: every src/ + tests/ .lua file, not
# just the ones staged. A clean tree before commit means whoever pulls
# this commit gets a green `make -j4` too. ~8s on this codebase.
if ! lua_out=$(cd "$REPO_ROOT" && luacheck src tests 2>&1); then
    echo "PRE-COMMIT BLOCKED: luacheck reports warnings or errors." >&2
    echo "" >&2
    echo "$lua_out" >&2
    echo "" >&2
    echo "Fix the warnings before committing." >&2
    exit 1
fi

# --- 3) anti-pattern lint ----------------------------------------------------
LINT="$REPO_ROOT/scripts/lint_anti_patterns.sh"
STAGED=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(lua|cpp|h|hpp|mm)$' || true)

if [ -x "$LINT" ] && [ -n "$STAGED" ]; then
    violations_blocked=0
    violations_total=0
    report=$(mktemp)
    trap 'rm -f "$report"' EXIT

    for f in $STAGED; do
        [ ! -f "$f" ] && continue
        lint_out=$("$LINT" "$f" 2>/dev/null)
        [ -z "$lint_out" ] && continue

        added_lines=$(git diff --cached -U0 -- "$f" \
            | awk '
                /^@@/ {
                    split($3, parts, ",");
                    start = parts[1] + 0;
                    if (start < 0) start = -start;
                    count = (length(parts) > 1) ? parts[2] + 0 : 1;
                    for (i = 0; i < count; i++) print start + i;
                }
            ')

        while IFS= read -r vline; do
            violations_total=$((violations_total + 1))
            ln=$(echo "$vline" | awk -F: '{print $2}')
            if echo "$added_lines" | grep -qx "$ln"; then
                echo "$vline" >> "$report"
                violations_blocked=$((violations_blocked + 1))
            fi
        done <<< "$lint_out"
    done

    if [ "$violations_blocked" -gt 0 ]; then
        echo "PRE-COMMIT BLOCKED: $violations_blocked anti-pattern violation(s) on added lines." >&2
        echo "" >&2
        cat "$report" >&2
        echo "" >&2
        echo "Fix the violations, or add a per-line exemption with explicit reason:" >&2
        echo "  -- lint-allow: <rule_id> <reason>   (Lua)" >&2
        echo "  // lint-allow: <rule_id> <reason>   (C++)" >&2
        echo "" >&2
        echo "Bypass this commit only: git commit --no-verify (not recommended)." >&2
        exit 1
    fi

    if [ "$violations_total" -gt 0 ]; then
        echo "[lint] $violations_total pre-existing violation(s) on unchanged lines (not blocking)." >&2
    fi
fi

# --- 4) lint-allow gate ------------------------------------------------------
# Every newly added `lint-allow:` annotation gets surfaced for review. The
# point: prevent the "shut up the linter" shortcut. If a rule fires, the
# default action is to FIX the code; lint-allow is the exception, not the
# escape hatch. To proceed when an allow is genuinely justified, opt-in
# explicitly with `JVE_LINT_ALLOW_OK=1 git commit ...`.
allow_lines=""
for f in $STAGED; do
    [ ! -f "$f" ] && continue
    diff_out=$(git diff --cached -U0 -- "$f" 2>/dev/null | grep -E '^\+' | grep -v '^+++' | grep -E 'lint-allow:' || true)
    [ -z "$diff_out" ] && continue
    while IFS= read -r line; do
        clean="${line#+}"
        allow_lines+="$f: $clean"$'\n'
    done <<< "$diff_out"
done

if [ -n "$allow_lines" ]; then
    if [ "${JVE_LINT_ALLOW_OK:-0}" = "1" ]; then
        echo "[lint-allow gate] $(echo "$allow_lines" | grep -c .) new lint-allow annotation(s) — proceeding (JVE_LINT_ALLOW_OK=1)" >&2
    else
        echo "PRE-COMMIT PAUSED: this commit adds lint-allow annotation(s)." >&2
        echo "" >&2
        echo "$allow_lines" >&2
        echo "lint-allow is for cases where the code is genuinely correct and" >&2
        echo "the linter is wrong, NOT for ducking a real fix. Read each one." >&2
        echo "If still right, retry with JVE_LINT_ALLOW_OK=1 git commit ..." >&2
        exit 1
    fi
fi

exit 0

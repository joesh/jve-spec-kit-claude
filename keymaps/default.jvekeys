# JVE Editor Default Keybindings
# Format: "KeyCombo" = "CommandName [args...] [@context ...]"
# Contexts: @timeline @source_monitor @timeline_monitor @project_browser
# No context suffix = global (active in any panel)
#
# Args:
#   Positional:  "MovePlayhead 1f" — first token after command name
#   Named:       "DeleteSelection ripple=true"
#   Duration:    1f (1 frame), -1s (minus 1 second), 30f (30 frames)

[Application]
"Cmd+Q" = "Quit"
"Cmd+N" = "NewProject"
"Cmd+O" = "OpenProject"
"Cmd+S" = "SaveProject"
"Cmd+Shift+S" = "SaveProjectAs"
"Cmd+I" = "ImportMedia"
"Cmd+Shift+R" = "ShowRelinkDialog"
"Cmd+Alt+K" = "ShowKeyboardCustomization"
"Cmd+Z" = "Undo"
"Cmd+Shift+Z" = "Redo"
"Ctrl+G" = "GoToTimecode @timeline"
"Cmd+X" = "Cut @timeline"
"Cmd+C" = "Copy @timeline"
"Cmd+V" = "Paste @timeline"
"F1" = "OpenUserManual"
"F12" = "ReportBug"
"Shift+F12" = "ToggleProfiler"

[Transport]
# 017 FR-020 transport-class: fires from every focus context that can
# carry a transport (timeline panel, both monitors). Routing to the
# displayed side happens via command_manager's sequence_id auto-injection
# (see inject_sequence_context).
"Space" = "TogglePlay @timeline @source_monitor @timeline_monitor"
"J" = "ShuttleReverse @timeline @source_monitor @timeline_monitor"
"K" = "ShuttleStop @timeline @source_monitor @timeline_monitor"
"L" = "ShuttleForward @timeline @source_monitor @timeline_monitor"
"Grave" = "ToggleSourceRecordTab @timeline @source_monitor @timeline_monitor"

[Navigation]
# 017 FR-020 movement-class: same multi-scope reach as Transport. Acts on
# transport.engine_for_target().loaded_sequence_id via auto-injection.
"Home" = "GoToStart @timeline @source_monitor @timeline_monitor"
"End" = "GoToEnd @timeline @source_monitor @timeline_monitor"
"Up" = "GoToPrevEdit @timeline @source_monitor @timeline_monitor"
"Down" = "GoToNextEdit @timeline @source_monitor @timeline_monitor"
# Left/Right handled in keyboard_shortcuts.lua (arrow repeat management)
"Tab" = "ToggleTimecodeFocus @timeline"
# Shift+Tab intentionally unbound — user-mappable via the keyboard customization UI

[Marks]
# 017 FR-020 movement-class: mark commands target the displayed side
# (source tab → master marks; record tab → timeline marks).
# 019: plain SetMark stays bound only to timeline scopes. The source
# monitor's I/O variant lives in the [SourceMonitor] section below —
# TOML disallows duplicate keys in one table, so the two commands have
# to be in separate sections even though both map to "I" and "O"
# physically. The runtime registry dedupes by (combo, scope), not by
# section — section is only a UI grouping label.
"I" = "SetMark in @timeline @timeline_monitor"
"O" = "SetMark out @timeline @timeline_monitor"
"Shift+I" = "GoToMark in @timeline @source_monitor @timeline_monitor"
"Shift+O" = "GoToMark out @timeline @source_monitor @timeline_monitor"
"Alt+I" = "ClearMark in @timeline @source_monitor @timeline_monitor"
"Alt+O" = "ClearMark out @timeline @source_monitor @timeline_monitor"
"Alt+X" = "ClearMarks @timeline @source_monitor @timeline_monitor"
"X" = "MarkClipExtent @timeline"

[Timeline]
# Selection
"Cmd+A" = "SelectAll @timeline"
"Cmd+Shift+A" = "DeselectAll @timeline"
# Editing
"Delete" = "DeleteSelection"
"Backspace" = "DeleteSelection"
"Shift+Delete" = "DeleteSelection ripple=true"
"Shift+Backspace" = "DeleteSelection ripple=true"
"Cmd+B" = "BladeAtPlayhead @timeline"
"Cmd+Shift+BracketLeft" = "TrimHead @timeline"
"Cmd+Shift+BracketRight" = "TrimTail @timeline"
"D" = "ToggleClipEnabled @timeline"
# 017 FR-021/021a: clip-context commands are global-scope so they reach
# every focus that can carry a selected clip (timeline_monitor included).
"F" = "MatchFrame"
"Alt+F" = "FindMasterClipInBrowser"
# 019 FR-024: Shift+F loads the timeline clip under the playhead into the
# source viewer in live-bound mode (retrim by setting marks). Distinct
# from F (MatchFrame) which loads the underlying master with copied marks.
"Shift+F" = "OpenClipInSourceMonitor"
# 019 FR-024a: RevealInFilesystem relocated from Shift+F to free that
# slot. Cmd+Opt+F verified unbound at the time of the move (2026-05-19).
"Cmd+Option+F" = "RevealInFilesystem"
"Cmd+L" = "LinkSelectedClips @timeline"
"Cmd+Shift+L" = "UnlinkSelectedClips @timeline"
"Cmd+Delete" = "CloseGap @timeline"
# Nudge keys: NudgeSelection routes to BatchRippleEdit (edges) or Nudge (clips)
# based on the active timeline selection. Magnitude lives in the binding so
# users can rebind nudge step from TOML alone.
"Comma"        = "NudgeSelection direction=-1 magnitude=1 @timeline"
"Period"       = "NudgeSelection direction=1 magnitude=1 @timeline"
"Shift+Comma"  = "NudgeSelection direction=-1 magnitude=5 @timeline"
"Shift+Period" = "NudgeSelection direction=1 magnitude=5 @timeline"
"E"            = "ExtendEdit @timeline"
"F9" = "Insert advance_playhead=true"
"F10" = "Overwrite advance_playhead=true"
# Zoom
# Plain Cmd+=/Cmd+- → zoom around playhead (or viewport center if playhead off-screen).
# Shift+Cmd+=/Shift+Cmd+- → zoom around the mouse pointer. Under the canonical
# key model, Cmd+Plus normalizes to Shift+Cmd+Equal, so both forms resolve here.
"Shift+Z" = "TimelineZoomFit @timeline"
"Cmd+Equal" = "TimelineZoomIn @timeline"
"Shift+Cmd+Equal" = "TimelineZoomInAtMouse @timeline"
"Cmd+Minus" = "TimelineZoomOut @timeline"
"Shift+Cmd+Minus" = "TimelineZoomOutAtMouse @timeline"
# Snapping
"N" = "ToggleSnapping @timeline"
# Tools
"Q" = "SelectTool @timeline"
"W" = "TrackSelectTool @timeline"
"R" = "RippleTool @timeline"
"T" = "RollTool @timeline"

[SourceMonitor]
# 019: source-monitor I/O is mode-aware — in live_bound_clip mode it
# dispatches a clip trim (Overwrite or Ripple per edit_mode); in
# staged_sequence mode it dispatches a nested SetMark on the staged
# sequence. Same physical key as @timeline's SetMark; disjoint scope.
# Lives in this section (not [Marks]) because TOML forbids two values
# for the same key inside one table.
"I" = "SetMarkAndTrimIfClip in @source_monitor"
"O" = "SetMarkAndTrimIfClip out @source_monitor"

# Source viewer mark bar zoom (same keys as timeline zoom, different context)
"Cmd+Equal" = "SourceZoomIn @source_monitor"
"Shift+Cmd+Equal" = "SourceZoomIn @source_monitor"
"Cmd+Minus" = "SourceZoomOut @source_monitor"
"Shift+Z" = "SourceZoomFit @source_monitor"

[View]
"Cmd+1" = "SelectPanel source_monitor"
"Cmd+2" = "SelectPanel inspector"
"Cmd+3" = "SelectPanel timeline"
"Cmd+4" = "SelectPanel project_browser"
"Tilde" = "ToggleMaximizePanel"
"Cmd+Shift+F" = "ToggleFullscreenView"

[Find]
"Cmd+F" = "Find"
"Cmd+G" = "FindNext"
"Cmd+Shift+G" = "FindPrevious"

[Browser]
# Return handled natively: tree keymap (activate/toggle) + PanelFocusTrap (button click)
"F2" = "StartRename @project_browser"
"Cmd+Shift+N" = "NewBinHere @project_browser"

# JVE Editor Default Keybindings
# Format: "KeyCombo" = "CommandName [args...] [@context ...]"
# Contexts: @timeline @source_monitor @timeline_monitor @project_browser
# No context suffix = global (active in any panel)
#
# Args:
#   Positional:  "MovePlayhead 1f" — first token after command name
#   Named:       "DeleteSelection ripple=true"
#   Duration:    1f (1 frame), -1s (minus 1 second), 30f (30 frames)

[Application]
"Cmd+Q" = "Quit"
"Cmd+N" = "NewProject"
"Cmd+O" = "OpenProject"
"Cmd+S" = "SaveProject"
"Cmd+Shift+S" = "SaveProjectAs"
"Cmd+I" = "ImportMedia"
"Cmd+Shift+R" = "ShowRelinkDialog"
"Cmd+Alt+K" = "ShowKeyboardCustomization"
"Cmd+Z" = "Undo"
"Cmd+Shift+Z" = "Redo"
"Ctrl+G" = "GoToTimecode @timeline"
"Cmd+X" = "Cut @timeline"
"Cmd+C" = "Copy @timeline"
"Cmd+V" = "Paste @timeline"
"F1" = "OpenUserManual"
"F12" = "ReportBug"
"Shift+F12" = "ToggleProfiler"

[Transport]
"Space" = "TogglePlay @timeline @source_monitor @timeline_monitor"
"J" = "ShuttleReverse @timeline @source_monitor @timeline_monitor"
"K" = "ShuttleStop @timeline @source_monitor @timeline_monitor"
"L" = "ShuttleForward @timeline @source_monitor @timeline_monitor"

[Navigation]
"Home" = "GoToStart @timeline @source_monitor"
"End" = "GoToEnd @timeline @source_monitor"
"Up" = "GoToPrevEdit @timeline @source_monitor"
"Down" = "GoToNextEdit @timeline @source_monitor"
# Left/Right handled in keyboard_shortcuts.lua (arrow repeat management)
"Tab" = "ToggleTimecodeFocus @timeline"
# Shift+Tab intentionally unbound — user-mappable via the keyboard customization UI

[Marks]
"I" = "SetMark in @timeline @source_monitor"
"O" = "SetMark out @timeline @source_monitor"
"Shift+I" = "GoToMark in @timeline @source_monitor"
"Shift+O" = "GoToMark out @timeline @source_monitor"
"Alt+I" = "ClearMark in @timeline @source_monitor"
"Alt+O" = "ClearMark out @timeline @source_monitor"
"Alt+X" = "ClearMarks @timeline @source_monitor"
"X" = "MarkClipExtent @timeline"

[Timeline]
# Selection
"Cmd+A" = "SelectAll @timeline"
"Cmd+Shift+A" = "DeselectAll @timeline"
# Editing
"Delete" = "DeleteSelection"
"Backspace" = "DeleteSelection"
"Shift+Delete" = "DeleteSelection ripple=true"
"Shift+Backspace" = "DeleteSelection ripple=true"
"Cmd+B" = "Blade @timeline"
"Cmd+Shift+BracketLeft" = "TrimHead @timeline"
"Cmd+Shift+BracketRight" = "TrimTail @timeline"
"D" = "ToggleClipEnabled @timeline"
"F" = "MatchFrame @timeline"
"Alt+F" = "FindMasterClipInBrowser @timeline @source_monitor"
"Shift+F" = "RevealInFilesystem @timeline"
"Cmd+L" = "LinkClips @timeline"
"Cmd+Shift+L" = "UnlinkClips @timeline"
"Cmd+Delete" = "CloseGap @timeline"
# Nudge keys: NudgeSelection routes to BatchRippleEdit (edges) or Nudge (clips)
# based on the active timeline selection. Magnitude lives in the binding so
# users can rebind nudge step from TOML alone.
"Comma"        = "NudgeSelection direction=-1 magnitude=1 @timeline"
"Period"       = "NudgeSelection direction=1 magnitude=1 @timeline"
"Shift+Comma"  = "NudgeSelection direction=-1 magnitude=5 @timeline"
"Shift+Period" = "NudgeSelection direction=1 magnitude=5 @timeline"
"E"            = "ExtendEdit @timeline"
"F9" = "Insert advance_playhead=true"
"F10" = "Overwrite advance_playhead=true"
# Zoom
# Plain Cmd+=/Cmd+- → zoom around playhead (or viewport center if playhead off-screen).
# Shift+Cmd+=/Shift+Cmd+- → zoom around the mouse pointer. Under the canonical
# key model, Cmd+Plus normalizes to Shift+Cmd+Equal, so both forms resolve here.
"Shift+Z" = "TimelineZoomFit @timeline"
"Cmd+Equal" = "TimelineZoomIn @timeline"
"Shift+Cmd+Equal" = "TimelineZoomInAtMouse @timeline"
"Cmd+Minus" = "TimelineZoomOut @timeline"
"Shift+Cmd+Minus" = "TimelineZoomOutAtMouse @timeline"
# Snapping
"N" = "ToggleSnapping @timeline"
# Tools
"Q" = "SelectTool @timeline"
"W" = "TrackSelectTool @timeline"
"R" = "RippleTool @timeline"
"T" = "RollTool @timeline"

[SourceMonitor]
# Source viewer mark bar zoom (same keys as timeline zoom, different context)
"Cmd+Equal" = "SourceZoomIn @source_monitor"
"Shift+Cmd+Equal" = "SourceZoomIn @source_monitor"
"Cmd+Minus" = "SourceZoomOut @source_monitor"
"Shift+Z" = "SourceZoomFit @source_monitor"

[View]
"Cmd+1" = "SelectPanel source_monitor"
"Cmd+2" = "SelectPanel inspector"
"Cmd+3" = "SelectPanel timeline"
"Cmd+4" = "SelectPanel project_browser"
"Tilde" = "ToggleMaximizePanel"
"Cmd+Shift+F" = "ToggleFullscreenView"

[Find]
"Cmd+F" = "Find"
"Cmd+G" = "FindNext"
"Cmd+Shift+G" = "FindPrevious"

[Browser]
# Return handled natively: tree keymap (activate/toggle) + PanelFocusTrap (button click)
"F2" = "StartRename @project_browser"
"Cmd+Shift+N" = "NewBin @project_browser"

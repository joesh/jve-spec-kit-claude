<?xml version="1.0" encoding="UTF-8"?>
<menus>
  <!-- File Menu -->
  <menu name="File">
    <item name="New Project..." command="NewProject"/>
    <item name="Open Project..." command="OpenProject"/>
    <separator/>
    <menu name="Import">
      <item name="Media Files..." command="ImportMedia"/>
      <item name="Resolve Project (.drp)..." command="ImportResolveProject"/>
      <item name="Resolve Database..." command="ImportResolveDatabase"/>
      <item name="FCP7 XML..." command="ImportFCP7XML"/>
      <item name="Premiere XML..." command="ImportPremiereXML"/>
    </menu>
    <menu name="Export">
      <item name="FCP7 XML..." command="ExportFCP7XML"/>
      <item name="Premiere XML..." command="ExportPremiereXML"/>
      <item name="EDL..." command="ExportEDL"/>
    </menu>
    <separator/>
    <item name="Save Project" command="SaveProject"/>
    <item name="Save Project As..." command="SaveProjectAs"/>
    <separator/>
    <item name="Project Settings..." command="ProjectSettings"/>
    <separator/>
    <item name="Quit" command="Quit"/>
  </menu>

  <!-- Edit Menu -->
  <menu name="Edit">
    <item name="Undo" command="Undo"/>
    <item name="Redo" command="Redo"/>
    <item name="Edit History..." command="EditHistory"/>
    <separator/>
    <item name="Cut" command="Cut"/>
    <item name="Copy" command="Copy"/>
    <item name="Paste" command="Paste"/>
    <item name="Delete" command="DeleteSelection"/>
    <separator/>
    <item name="Select All" command="SelectAll"/>
    <item name="Deselect All" command="DeselectAll"/>
    <separator/>
    <item name="Keyboard Shortcuts..." command="ShowKeyboardCustomization"/>
  </menu>

  <!-- Clip Menu -->
  <menu name="Clip">
    <item name="Split" command="Split"/>
    <item name="Link Clips" command="LinkClips"/>
    <item name="Unlink Clips" command="UnlinkClips"/>
    <separator/>
    <item name="Nudge Left" command="Nudge" params="{delta_ms=-33}"/>
    <item name="Nudge Right" command="Nudge" params="{delta_ms=33}"/>
    <separator/>
    <item name="Enable/Disable" command="ToggleClipEnabled"/>
    <separator/>
    <item name="Match Frame" command="MatchFrame"/>
    <item name="Reveal in Filesystem" command="RevealInFilesystem"/>
  </menu>

  <!-- Timeline Menu -->
  <menu name="Timeline">
    <item name="Insert" command="Insert"/>
    <item name="Overwrite" command="Overwrite"/>
    <item name="Replace" command="Replace"/>
    <separator/>
    <item name="Ripple Delete" command="RippleDelete"/>
    <item name="Close Gap" command="CloseGap"/>
    <separator/>
    <item name="Zoom In" command="TimelineZoomIn"/>
    <item name="Zoom Out" command="TimelineZoomOut"/>
    <item name="Zoom to Fit" command="TimelineZoomFit"/>
    <separator/>
    <item name="Go to Start" command="GoToStart"/>
    <item name="Go to End" command="GoToEnd"/>
    <item name="Go to Timecode..." command="GoToTimecode"/>
  </menu>

  <!-- Media Menu -->
  <menu name="Media">
    <item name="New Bin" command="NewBin"/>
    <item name="Rename..." command="RenameItem"/>
    <separator/>
    <item name="Relink Media..." command="ShowRelinkDialog"/>
    <item name="Consolidate Media..." command="ConsolidateMedia"/>
    <separator/>
    <item name="Tag Media..." command="TagMedia"/>
    <item name="Manage Tags..." command="ManageTags"/>
  </menu>

  <!-- Window Menu -->
  <menu name="Window">
    <item name="Show Project Browser" command="ShowProjectBrowser" checkable="true"/>
    <item name="Show Timeline" command="ShowTimeline" checkable="true"/>
    <item name="Show Inspector" command="ShowInspector" checkable="true"/>
    <item name="Show Viewer" command="ShowViewer" checkable="true"/>
    <separator/>
    <item name="Toggle Panel Maximize" command="ToggleMaximizePanel"/>
    <separator/>
    <menu name="Workspace">
      <item name="Editing" command="LoadWorkspace" params="{name='editing'}"/>
      <item name="Color" command="LoadWorkspace" params="{name='color'}"/>
      <item name="Audio" command="LoadWorkspace" params="{name='audio'}"/>
      <item name="Effects" command="LoadWorkspace" params="{name='effects'}"/>
      <separator/>
      <item name="Save Workspace..." command="SaveWorkspace"/>
      <item name="Manage Workspaces..." command="ManageWorkspaces"/>
    </menu>
  </menu>

  <!-- Help Menu -->
  <menu name="Help">
    <item name="User Manual" command="OpenUserManual"/>
    <item name="Keyboard Shortcuts Reference" command="OpenShortcutsReference"/>
    <separator/>
    <item name="Report Bug..." command="ReportBug"/>
    <item name="Check for Updates..." command="CheckUpdates"/>
    <separator/>
    <item name="About JVE Editor" command="ShowAbout"/>
  </menu>
</menus>

CPackSourceConfig.cmake
_CPack_Packages/

# Binaries
*.exe
*.dll
*.so
*.dylib
*.a
*.lib
bin/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# System files
.DS_Store
Thumbs.db

# Logs
*.log

# Local scratch review artifacts
review*.txt

# Project and database files
*.db
*.jvp
*.test.db
test_*.jve
*.sqlite
*.sqlite-*
*.jvp-wal
*.jvp-shm
eventlog/

# Temporary files
*.tmp
*.temp
*.bak
*.orig

# Python cache
__pycache__/
*.pyc
*.pyo

# Test capture artifacts (screenshots/logs)
tests/captures/
tests/**/captures/

# Event journals (runtime artifacts)
:memory:.events/
**/events.jsonl

# Package files
*.deb
*.rpm
*.pkg
*.dmg

# Generated Qt/CMake autogen artifacts
*_autogen/
tests/temp/
tests/tests/
.aider*

# Local Claude Code settings
.claude/settings.local.json

# Claude Code worktree scratch (per-agent isolation; not source)
.claude/worktrees/

# Graphify cache + reports (regenerable from the project; not source)
graphify-out/

# Local JVE projects copied/dropped into the repo while debugging
JVE/

# Test output
test-errors.txt

# Large media fixtures (real project media, not for VCS)
tests/fixtures/media

# speckit active-feature marker (per-working-tree state; branch deferred to /implement)
.specify/.active-feature

# cozempic guard runtime lock (per-session daemon PID/state — not VCS)
.claude/scheduled_tasks.lock

# pre-commit clean-build marker (touched by `make -j4` on green finish)
.last-clean-make
